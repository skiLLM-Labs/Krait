{
  "name": "krait-language",
  "displayName": "Krait Language Support",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "krait",
        "aliases": ["Krait", "krait"],
        "extensions": [".krait"]
      }
    ],
    "grammars": [
      {
        "language": "krait",
        "scopeName": "source.krait",
        "path": "./krait.tmLanguage.json"
      }
    ]
  }
}
