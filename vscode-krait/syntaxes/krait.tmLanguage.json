{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Krait",
  "scopeName": "source.krait",
  "patterns": [
    {
      "match": "\\b(make|set|when|repeat|times|show|return)\\b",
      "name": "keyword.control.krait"
    },
    {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.krait"
    },
    {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.krait"
    },
    {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.krait"
    },
    {
      "match": "#.*$",
      "name": "comment.line.number-sign.krait"
    },
    {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "name": "entity.name.function.krait"
    }
  ]
}